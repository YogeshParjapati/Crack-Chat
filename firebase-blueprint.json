{
  "entities": {
    "Room": {
      "title": "Room",
      "description": "A chat room",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the room" },
        "hasPassword": { "type": "boolean", "description": "Whether the room has a password" },
        "password": { "type": "string", "description": "The password for the room" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" },
        "permanent": { "type": "boolean", "description": "Whether the room is permanent and cannot be deleted" }
      },
      "required": ["name", "createdAt"]
    },
    "Presence": {
      "title": "Presence",
      "description": "User presence in a room",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user" },
        "lastSeen": { "type": "number", "description": "Timestamp of last activity" }
      },
      "required": ["userId", "lastSeen"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The message text" },
        "sender": { "type": "string", "description": "The sender's name" },
        "color": { "type": "string", "description": "The sender's color" },
        "type": { "type": "string", "enum": ["text", "emoji", "gif", "sticker", "image", "video"], "description": "The type of message" },
        "url": { "type": "string", "description": "The URL for media messages (base64 for images/videos < 500KB)" },
        "timestamp": { "type": "number", "description": "Timestamp of the message" },
        "uid": { "type": "string", "description": "The sender's UID" },
        "replyTo": {
          "type": "object",
          "properties": {
            "text": { "type": "string" },
            "sender": { "type": "string" }
          }
        }
      },
      "required": ["text", "sender", "color", "type", "timestamp", "uid"]
    },
    "Call": {
      "title": "Call",
      "description": "A call signaling document",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["voice", "video"] },
        "status": { "type": "string", "enum": ["calling", "active", "ended"] },
        "callerId": { "type": "string" },
        "callerName": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["type", "status", "callerId", "callerName"]
    }
  },
  "firestore": {
    "/rooms": {
      "schema": "Room",
      "description": "Collection of chat rooms"
    },
    "/rooms/{roomId}/messages": {
      "schema": "Message",
      "description": "Collection of messages within a room"
    },
    "/rooms/{roomId}/presence": {
      "schema": "Presence",
      "description": "Collection of active users in a room"
    },
    "/rooms/{roomId}/calls": {
      "schema": "Call",
      "description": "Collection of active calls in a room"
    }
  }
}
