{
  "entities": {
    "Room": {
      "title": "Chat Room",
      "description": "A room where users can chat.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the room."
        },
        "password": {
          "type": "string",
          "description": "Optional password for the room."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the room was created."
        },
        "createdBy": {
          "type": "string",
          "description": "The UID of the user who created the room."
        }
      },
      "required": ["name", "createdAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A message sent in a room.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The text content of the message."
        },
        "sender": {
          "type": "string",
          "description": "The codename of the sender."
        },
        "color": {
          "type": "string",
          "description": "The color class for the sender's name."
        },
        "type": {
          "type": "string",
          "enum": ["text", "emoji", "gif", "sticker"],
          "description": "The type of message."
        },
        "url": {
          "type": "string",
          "description": "The URL for GIF or sticker messages."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent."
        },
        "uid": {
          "type": "string",
          "description": "The UID of the sender."
        }
      },
      "required": ["sender", "timestamp", "type"]
    }
  },
  "firestore": {
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Collection of chat rooms."
    },
    "/rooms/{roomId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific room."
    }
  }
}
